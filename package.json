{
  "name": "product-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:up": "docker compose -f docker/docker-compose.yml up postgres redis -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:migrate": "docker compose -f docker/docker-compose.yml exec -T postgres psql -U postgres -d productdb -f /migrations/001_create_products.sql",
    "lb:up": "docker compose -f docker/docker-compose.yml up --build -d",
    "lb:down": "docker compose -f docker/docker-compose.yml down",
    "test:k6": "docker run --rm -e BASE_URL=http://host.docker.internal -v \"%cd%/scripts/k6:/scripts\" grafana/k6 run /scripts/smoke.js",
    "test:k6:health": "docker run --rm -e BASE_URL=http://host.docker.internal -v \"%cd%/scripts/k6:/scripts\" grafana/k6 run /scripts/health.js",
    "test:k6:lb": "docker run --rm -e BASE_URL=http://host.docker.internal -v \"%cd%/scripts/k6:/scripts\" grafana/k6 run /scripts/load-balancer.js",
    "test:k6:rate-limit": "docker run --rm -e BASE_URL=http://host.docker.internal -v \"%cd%/scripts/k6:/scripts\" grafana/k6 run /scripts/rate-limit.js",
    "test": "npm run test:k6:health"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshatsoni123/Product-API.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/akshatsoni123/Product-API/issues"
  },
  "homepage": "https://github.com/akshatsoni123/Product-API#readme",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
